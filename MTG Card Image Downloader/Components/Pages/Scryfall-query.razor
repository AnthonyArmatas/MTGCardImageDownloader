@page "/scryfall-query"
@rendermode InteractiveServer
@inject IHttpClientFactory HttpClientFactory

@using System.Text.Json
@using System.Text.RegularExpressions
@using System.IO
@using System;
@* @using Photoshop; *@
@* @using Interop.Photoshop; *@

<h3>Scryfall PNG Downloader (single + double-faced)</h3>

<textarea @bind="InputText"
          rows="6"
          cols="80"
          placeholder="e.g. 1 Asceticism (PLST) SOM-110 …"></textarea>
<br />
<button class="btn btn-primary" @onclick="ProcessInput">Download PNGs</button>

@* <button class="btn btn-primary" @onclick="ProcessImagesToPng">Export PNG sheet</button> *@


@if (Messages.Any())
{
    <ul class="mt-3">
        @foreach (var m in Messages)
        {
            <li>@m</li>
        }
    </ul>
}

@code {
    private string InputText { get; set; } = "";
    private List<string> Messages { get; set; } = new();

    // Hard-coded download folder
    private readonly string DownloadFolder = Path.Combine(
        Directory.GetCurrentDirectory(), "wwwroot", "downloaded-pngs"
    );

    private async Task ProcessInput()
    {
        Messages.Clear();
        Directory.CreateDirectory(DownloadFolder);
        Messages.Add($"➡️ Saving to {DownloadFolder}");

        var client = HttpClientFactory.CreateClient("ExternalScryfall");
        var lines = InputText
            .Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries);

        foreach (var line in lines)
        {
            // capture SET in () and collector # (including dashes, letters, etc.)
            var m = Regex.Match(line, @"\((\w+)\)\s*([^\s#]+)");
            if (!m.Success)
            {
                Messages.Add($"❓ Skipping unparseable: “{line}”");
                continue;
            }

            var setCode = m.Groups[1].Value;        // e.g. "PLST" or "ZNR"
            var collectorNum = m.Groups[2].Value;        // e.g. "SOM-110" or "261"
            var endpoint = $"https://api.scryfall.com/cards/{setCode}/{collectorNum}";

            try
            {
                // 1) Fetch JSON with headers
                var jsonReq = new HttpRequestMessage(HttpMethod.Get, endpoint);
                jsonReq.Headers.UserAgent.ParseAdd("MTGCardImageDownloader/1.0");
                jsonReq.Headers.Accept.ParseAdd("application/json");
                var jsonResp = await client.SendAsync(jsonReq);
                jsonResp.EnsureSuccessStatusCode();

                var json = await jsonResp.Content.ReadAsStringAsync();
                using var doc = JsonDocument.Parse(json);
                var root = doc.RootElement;

                // 2) Decide single-face vs double-face
                if (root.TryGetProperty("image_uris", out var rootImgs))
                {
                    // single-face
                    await DownloadAndSave(rootImgs.GetProperty("png").GetString()!,
                                          $"{setCode}_{collectorNum}.png",
                                          client);
                }
                else if (root.TryGetProperty("card_faces", out var faces) &&
                         faces.ValueKind == JsonValueKind.Array)
                {
                    // double-faced: loop each face
                    foreach (var face in faces.EnumerateArray())
                    {
                        var faceName = face.GetProperty("name").GetString()!;
                        // sanitize to filename safe (remove spaces/slashes/etc.)
                        var safeFace = Regex.Replace(faceName, @"\W+", "");
                        var imgs = face.GetProperty("image_uris");
                        var pngUrl = imgs.GetProperty("png").GetString();
                        if (string.IsNullOrEmpty(pngUrl))
                        {
                            Messages.Add($"⚠️ No PNG URL for face {faceName}");
                            continue;
                        }

                        await DownloadAndSave(pngUrl,
                                              $"{setCode}_{collectorNum}_{safeFace}.png",
                                              client);
                    }
                }
                else
                {
                    Messages.Add($"⚠️ No image_uris or card_faces for {setCode}/{collectorNum}");
                }
            }
            catch (Exception ex)
            {
                Messages.Add($"❌ [{setCode}/{collectorNum}] {ex.Message}");
            }
        }
    }

